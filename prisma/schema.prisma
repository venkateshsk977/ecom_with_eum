generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// FILE: models\catalog\category.prisma
model Category {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique

  parentId    String?
  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")

  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)

  products    Product[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([parentId])
  @@map("categories")
}

// FILE: models\catalog\product.prisma
model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  slug        String   @unique
  name        String

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  inventory   Inventory?
  cartItems   CartItem[]
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// FILE: models\checkout\address.prisma
enum AddressType {
  SHIPPING
  BILLING
}

model Address {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  orders      Order[]

  type        AddressType
  isDefault   Boolean  @default(false)

  fullName    String
  line1       String
  city        String
  state       String
  postalCode  String
  country     String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// FILE: models\checkout\cart-item.prisma
model CartItem {
  id          String   @id @default(uuid())

  cartId      String
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, productId])
  @@map("cart_items")
}

// FILE: models\checkout\cart.prisma
model Cart {
  id          String     @id @default(uuid())

  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id])

  items       CartItem[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("carts")
}

// FILE: models\identity\role.prisma
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

// FILE: models\identity\user.prisma
enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}
model User {
  id          String     @id @default(uuid())
  eumId       String     @unique
  fullName    String
  email       String     @unique

  roleId      String
  role        Role       @relation(fields: [roleId], references: [id])

  cart        Cart?
  addresses   Address[]
  orders      Order[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// FILE: models\inventory\inventory.prisma
model Inventory {
  id                String   @id @default(uuid())

  productId         String   @unique
  product           Product  @relation(fields: [productId], references: [id])

  totalQuantity     Int      @default(0)
  reservedQuantity  Int      @default(0)
  minThreshold      Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([minThreshold])
  @@map("inventory")
}

// FILE: models\order\order-item.prisma
model OrderItem {
  id           String   @id @default(uuid())

  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId    String
  product      Product  @relation(fields: [productId], references: [id])

  quantity     Int

  unitPrice    Decimal  @db.Decimal(10,2)
  totalPrice   Decimal  @db.Decimal(10,2)

  createdAt    DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

// FILE: models\order\order.prisma
enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id              String      @id @default(uuid())

  orderNumber     String      @unique

  userId          String
  user            User        @relation(fields: [userId], references: [id])

  addressId       String
  address         Address     @relation(fields: [addressId], references: [id])

  status          OrderStatus @default(PENDING)

  subtotalAmount  Decimal     @db.Decimal(10,2)
  taxAmount       Decimal     @db.Decimal(10,2)
  shippingAmount  Decimal     @db.Decimal(10,2)
  totalAmount     Decimal     @db.Decimal(10,2)

  items           OrderItem[]
  payments        Payment[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

// FILE: models\payments\payment.prisma
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Payment {
  id             String        @id @default(uuid())

  orderId        String
  order          Order         @relation(fields: [orderId], references: [id])

  gatewayName    String
  transactionId  String?       @unique

  amount         Decimal       @db.Decimal(10,2)

  status         PaymentStatus @default(PENDING)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("payments")
}