enum AddressType {
  SHIPPING
  BILLING
}

model Address {
  id          String   @id @default(uuid())

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  orders      Order[]

  type        AddressType
  isDefault   Boolean  @default(false)

  fullName    String
  line1       String
  line2       String?
  city        String
  state       String
  postalCode  String
  country     String
  phone       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}