model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  slug        String   @unique
  name        String

  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  inventory   Inventory?
  cartItems   CartItem[]
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}