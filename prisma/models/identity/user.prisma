enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}
model User {
  id          String     @id @default(uuid())
  eumId       String     @unique
  fullName    String
  email       String     @unique

  roleId      String
  role        Role       @relation(fields: [roleId], references: [id])

  cart        Cart?
  addresses   Address[]
  orders      Order[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}