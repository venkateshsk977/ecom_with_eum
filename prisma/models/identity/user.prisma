enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model User {
  id          String     @id @default(uuid())
  eumId       String     @unique
  fullName    String
  email       String     @unique
  status      UserStatus @default(ACTIVE)

  roleId      String
  role        Role       @relation(fields: [roleId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}